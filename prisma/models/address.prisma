model Country {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  provinces Province[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("countries")
}

model Province {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  countryId String   @map("country_id") @db.Uuid
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  // This is the code from the geojson, which is unique within a country. Useful for seeding.
  code      String
  type      String

  centroidLat Float  @map("centroid_lat")
  centroidLng Float  @map("centroid_lng")

  wards      Ward[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([countryId])
  @@unique([code, countryId]) // Of course name also should be unique.
  @@map("provinces")
}


model Ward {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  provinceId String   @map("province_id") @db.Uuid
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  // This is the code from the geojson, which is unique within a province. Useful for seeding.
  code      String
  type      String

  centroidLat Float  @map("centroid_lat")
  centroidLng Float  @map("centroid_lng")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt      @map("updated_at")

  hotel      Hotel[]

  @@index([provinceId])
  @@unique([code, provinceId]) // Of course name also should be unique.
  @@map("wards")
}