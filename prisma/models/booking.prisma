// TODO: when user selects room type to book, they first only sees a UI shows the form
// to fill in the information, and a "Continue to payment" button. Only after they click the button, we create a booking with status FILLING_INFORMATION, and then redirect them to the payment page. This way, we can prevent the issue of having many "abandoned" bookings with status PENDING_TO_PAY when user just clicks the button but never completes the payment.

// TODO: Prevent user from making a booking when he is holding another booking that is not yet expired.
// In such case, we force the user to either complete or cancel the existing booking before making a new one.
model Booking {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status       BookingStatus       @default(PENDING_TO_PAY)

  userId       String              @map("user_id") @db.Uuid
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomType     RoomType            @relation(fields: [roomTypeId], references: [id])
  roomTypeId   String              @map("room_type_id") @db.Uuid

  checkInDate          DateTime    @db.Date @map("check_in_date")
  checkOutDate         DateTime    @db.Date @map("check_out_date")

  numRooms             Int         @map("num_rooms")
  numAdults            Int         @map("num_adults")
  numChildren          Int         @map("num_children")
  snapshotRoomPrice    Decimal     @db.Decimal(19, 4) @map("snapshot_room_price") // VND
  snapshotRoomTypeName String      @map("snapshot_room_type_name")
  snapshotCheckInTime  DateTime    @map("snapshot_check_in_time") @db.Time(0)
  snapshotCheckOutTime DateTime    @map("snapshot_check_out_time") @db.Time(0)

  // TODO: allow user to book with other credentials or not? If yes, this should be called as snapshot, just like the snapshot...
  customerName      String           @map("customer_name")
  customerEmail     String           @map("customer_email")
  customerPhone     String           @map("customer_phone")
  notes             String?
  
  rooms             Room[]         // TODO: Only assign when check in. Done by hotel owner.
  review            Review?

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt      @map("updated_at")

  @@index([userId, roomTypeId])
  @@map("bookings")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating    Int      // 1..5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // TODO: reply logic
  reply     String?
  repliedAt DateTime? @map("replied_at")

  @@index([bookingId])
  @@index([createdAt])
  @@map("reviews")
}

enum BookingStatus {
  PENDING_TO_PAY
  PAID
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}