// TODO: Consider merge this with booking.
model BookingMetadata {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String      @map("user_id") @db.Uuid
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomType             RoomType    @relation(fields: [roomTypeId], references: [id])
  roomTypeId           String      @map("room_type_id") @db.Uuid

  checkInDate          DateTime    @db.Date @map("check_in_date")
  checkOutDate         DateTime    @db.Date @map("check_out_date")

  numRooms             Int         @map("num_rooms")
  numAdults            Int         @map("num_adults")
  numChildren          Int         @map("num_children")
  snapshotRoomPrice    Decimal     @db.Decimal(19, 4) @map("snapshot_room_price") // VND
  snapshotRoomTypeName String      @map("snapshot_room_type_name")
  snapshotCheckInTime  DateTime    @map("snapshot_check_in_time")
  snapshotCheckOutTime DateTime    @map("snapshot_check_out_time")
  
  booking           Booking?
  createdAt         DateTime       @default(now()) @map("created_at")
  
  status            BookingMetadataStatus @default(DRAFT)
  // how to automatically set the status to expired after some time to prevent holding ?
  expiredAt         DateTime       @map("expired_at") @default(dbgenerated("NOW() + INTERVAL '10 minutes'"))
  // TODO: what to index?
  @@index([userId])
  @@index([roomTypeId])

  @@map("booking_metadata")
}

enum BookingMetadataStatus {
  DRAFT
  SUCCESS
  EXPIRED
}

// TODO: Prevent user from making a booking when he is holding another booking that is not yet expired.
// In such case, we force the user to either complete or cancel the existing booking before making a new one.
model Booking {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rooms             Room[]         // TODO: Only assign when check in. Done by hotel owner.

  status            BookingStatus    @default(PENDING_TO_PAY)

  // allow user to book with other credentials.
  customerName      String           @map("customer_name")
  customerEmail     String           @map("customer_email")
  customerPhone     String           @map("customer_phone")
  notes             String?
  
  review            Review?

  // metadata is the draft step.
  metadata          BookingMetadata  @relation(fields: [metadataId], references: [id], onDelete: Cascade)
  metadataId        String           @unique @map("metadata_id") @db.Uuid

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt      @map("updated_at")

  @@index([metadataId])
  @@map("bookings")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating    Int      // 1..5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // TODO: reply logic
  reply     String?
  repliedAt DateTime? @map("replied_at")

  @@index([bookingId])
  @@index([createdAt])
  @@map("reviews")
}

enum BookingStatus {
  PENDING_TO_PAY
  PAID
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
  // REFUNDED // This is not supported yet.
}