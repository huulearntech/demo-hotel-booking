model Booking {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status       BookingStatus       @default(PENDING_TO_PAY)
  vnpayUrl     String?             @map("vnpay_url") // URL for payment, for continuing

  userId       String              @map("user_id") @db.Uuid
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomType     RoomType            @relation(fields: [roomTypeId], references: [id])
  roomTypeId   String              @map("room_type_id") @db.Uuid

  checkInDate          DateTime    @db.Date @map("check_in_date")
  checkOutDate         DateTime    @db.Date @map("check_out_date")

  numRooms             Int         @map("num_rooms")
  numAdults            Int         @map("num_adults")
  numChildren          Int         @map("num_children")
  snapshotRoomPrice    Decimal     @db.Decimal(19, 4) @map("snapshot_room_price") // VND
  snapshotRoomTypeName String      @map("snapshot_room_type_name")
  snapshotCheckInTime  DateTime    @map("snapshot_check_in_time") @db.Time(0)
  snapshotCheckOutTime DateTime    @map("snapshot_check_out_time") @db.Time(0)

  customerName      String           @map("customer_name")
  customerEmail     String           @map("customer_email")
  customerPhone     String           @map("customer_phone")
  notes             String?
  
  rooms             Room[]         // TODO: Only assign when check in. Done by hotel owner.
  review            Review?

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt      @map("updated_at")

  @@index([userId, roomTypeId])
  @@map("bookings")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating    Int      // 1..5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // TODO: reply logic
  reply     String?
  repliedAt DateTime? @map("replied_at")

  @@index([bookingId])
  @@index([createdAt])
  @@map("reviews")
}

enum BookingStatus {
  PENDING_TO_PAY
  PAID
  PAYMENT_FAILED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}